# Copy this file to .env.local and fill in the values from your Supabase project.

# Found in Supabase: Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Found in Supabase: Project Settings → API → Project API keys → anon (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Found in Supabase: Project Settings → API → Project API keys → service_role (secret)
# IMPORTANT: never expose this in the browser. Only used in server route handlers.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
